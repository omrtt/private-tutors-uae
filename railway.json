{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm install && cd .. && npm install"
  },
  "deploy": {
    "startCommand": "node backend/server.js",
    "healthcheckPath": "/api",
    "restartPolicyType": "always"
  }
}
