# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# MongoDB (optional - the app currently uses JSON file-based storage)
# MONGO_URI=mongodb://localhost:27017/private-tutors-uae

# SMTP (for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@tutors-uae.com

# Frontend (Vite) — used when deploying frontend separately from backend
# Set this to your deployed backend URL in Netlify environment variables
# Leave empty when using Netlify proxy redirects (_redirects file)
VITE_API_URL=
